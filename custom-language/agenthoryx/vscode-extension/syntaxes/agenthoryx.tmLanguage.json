{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Agenthoryx",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#constants"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.agenthoryx",
          "match": "\\b(if|else|while|return|agent|template|spawn|await)\\b"
        },
        {
          "name": "keyword.declaration.agenthoryx",
          "match": "\\b(let|fn|class)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.agenthoryx",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.agenthoryx",
          "match": "\\\\."
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.agenthoryx",
          "match": "//.*$"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.agenthoryx",
          "match": "\\b[0-9]+\\b"
        },
        {
          "name": "constant.language.agenthoryx",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    }
  },
  "scopeName": "source.agenthoryx"
}
