{
  "name": "agenthoryx",
  "displayName": "Agenthoryx Language Support",
  "description": "Language support for Agenthoryx, including syntax highlighting and language server integration.",
  "version": "1.0.0",
  "publisher": "agenthoryx-lang",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "contributes": {
    "languages": [
      {
        "id": "agenthoryx",
        "aliases": [
          "Agenthoryx",
          "agenthoryx"
        ],
        "extensions": [
          ".agx",
          ".axb"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "agenthoryx",
        "scopeName": "source.agenthoryx",
        "path": "./syntaxes/agenthoryx.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "agenthoryx.viewAST",
        "title": "Agenthoryx: View AST"
      },
      {
        "command": "agenthoryx.viewBytecode",
        "title": "Agenthoryx: View Generated Bytecode"
      }
    ]
  },
  "main": "./dist/extension.js"
}
